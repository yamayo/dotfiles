[user]
  name = yamayo
  email = noorthaven@gmail.com

[color]
  status = auto
  diff = auto
  branch = auto
  interactive = auto
  grep = auto

[core]
  editor = /usr/bin/vim

[alias]
  s = status
  sh = show
  br = branch
  ci = commit
  co = checkout
  hub = browse
  pr = pull-request

[help]
  autocorrect = -1

[hub]
  protocol = ssh

[ghq]
  root = ~/src

[pager]
  log = diff-highlight | less
  show = diff-highlight | less
  diff = diff-highlight | less
