[user]
	name = yamayo
	email = noorthaven@gmail.com

[url "git@github.com:"]
  insteadOf = https://github.com/

[color]
  status = auto
  diff = auto
  branch = auto
  interactive = auto
  grep = auto

[core]
  editor = /usr/bin/vim
  whitespace = cr-at-eol

[alias]
  s = status
  sh = show
  br = branch
  ci = commit
  co = checkout
  hub = browse
  pr = pull-request
  upush = !git push -u origin $(git rev-parse --abbrev-ref HEAD)
  upull = !git pull origin $(git rev-parse --abbrev-ref HEAD)

[help]
  autocorrect = -1

[hub]
  protocol = ssh

[ghq]
  root = ~/src
  # root = ~/go/src

# [pager]
  # log = diff-highlight | less
  # show = diff-highlight | less
  # diff = diff-highlight | less
[credential]
  helper = !aws codecommit credential-helper $@
  UseHttpPath = true
[pull]
	ff = only
[merge]
	ff = true
